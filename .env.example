# Copy this file to .env (or set these as real environment variables on your
# host) and fill in real values. Never commit a real .env file.

# Required to use the admin order-management page (pages/Admin.py).
# Pick any password yourself - it is not provided by any service.
ADMIN_PASSWORD=

# Optional. Only needed if you want online payment via Razorpay instead of
# the manual "we'll call you" flow. Get these from your Razorpay dashboard
# (Settings > API Keys) after creating a Razorpay account.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional. If you deploy to Streamlit Community Cloud, set this to a hosted
# Postgres connection string so orders survive redeploys (local SQLite is
# not durable there). Leave unset if self-hosting with a persistent disk.
DATABASE_URL=

# Optional. Only needed if you want customers to receive an order
# confirmation email. Example for Gmail: create an "app password" at
# myaccount.google.com/apppasswords and use it as SMTP_PASSWORD (not your
# normal Gmail password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# Optional. Only needed if you want every order to also be appended as a
# row to a live Google Sheet. See sheets_sync.py for the one-time Google
# Cloud setup steps. Use GOOGLE_SERVICE_ACCOUNT_FILE for a local file path,
# or GOOGLE_SERVICE_ACCOUNT_JSON to paste the key's JSON contents directly
# (useful for cloud secrets where uploading a file isn't convenient).
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
